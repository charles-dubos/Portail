{% extends 'base.html.j2' %}


{% block head %}
<link rel="stylesheet" href="{{url_for('static', filename='css/settings.css')}}">
<script src="{{url_for('static', filename='js/settings.js')}}"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
{%- endblock head -%}


{%- macro titleMenu() -%}
<span class="pure-menu-heading">Edition de configuration</span>
{%- endmacro -%}


{%- macro nav(classes='') -%}

<div class="pure-u-1-3 {{classes}} is-center"></div>
<div class="pure-u-1-3 {{classes}} is-center">
    <a href="/"
       class="pure-button"
       id="kbdHome">
        <i class="fa-solid fa-house"></i>
    </a>
</div>
<div class="pure-u-1-3 {{classes}} is-center"></div>
{%- endmacro -%}


{%- macro buttonright() -%}
{%- endmacro -%}


{%- macro cards() -%}
<div id="tabBar" class="pure-g settings-menu is-center">
{% for tab in [ ('Configurations locales','localTab'),
                ('Configuration des pages','pagesTab'),
                ('Configurations avancées','soundTab') ] %}
    <div forTab="{{ tab[1] }}"
         class="pure-u-1-{{loop.index+loop.revindex0}} {% if loop.index0 == activeTabIndex %}active{% endif %}"
         onclick="selectTab(this)">
        {{ tab[0] }}
    </div>
{% endfor %}
</div>
<div id='localTab' class="tabPage settings-menu is-center pure-form-aligned">
    <form class="pure-form" >
        <div class="pure-g">
            <div class="pure-u-3-5"> Nom de la page </div>
            <div class="pure-u-1-5"> Page principale </div>
            <div class="pure-u-1-5"> Page masquée </div>
        </div>
        <ul id="localPagesSettings" class="inlineList">
            {% for page in pages %}
            <li>
                <div class="pure-g">
                    <div class="pure-u-3-5"> {{ page.title }} </div>
                    <div class="pure-u-1-5">
                        <label for="home-{{ page.id }}" class="pure-radio">
                            <input id="home-{{ page.id }}"
                                type="radio" name="mainPage"
                                {# {% if page.id == mainPage %}checked=""{% endif %} #}
                                onclick="updateMainPage(this)"/>
                        </label>
                    </div>
                    <div class="pure-u-1-5">
                        <label for="mask-{{ page.id }}" class="pure-checkbox">
                            <input id="mask-{{ page.id }}"
                                type="checkbox" name="{{ page.id }}"
                                {# {% if page.id == mainPage %} disabled="" {% endif %} #}
                                onclick="switchMask(this)"
                                />
                        </label>
                    </div>
            </li>
        {% endfor %}
        </ul>
    </form>
    <div class="pure-control-group"> 
        <button class="pure-button"
                id="toggleMuted"
                onclick="appMuted.switch()">
            <i class="fa-solid fa-volume-high"></i>
        </button>
    </div>
    <div class="pure-control-group"> 
        <button class="pure-button"
                id="toggleDarkmode"
                onclick="darkMode.switch()">
            <i class="fa-solid fa-moon"></i>
        </button>
    </div>
</div>
<div id='pagesTab' class="tabPage settings-menu is-center">
    <form class="pure-form"
            method="post">
        <div class="pure-g">
            <div class="pure-u-1-4"> Identifiant de page </div>
            <div class="pure-u-1-4"> Titre de la page </div>
            <div class="pure-u-3-8"> URL de l'image de fond </div>
            <div class="pure-u-1-8"> </div>
        </div>
        <ul id="sortList" class="inlineList">
            {% for page in pages %}
            <li>
                <div class="pure-g">
                    <div class="pure-u-1-4 handle"> {{ page.id }} </div>
                    <div class="pure-u-1-4">
                        <input type="text"
                                name="{{ page.id }}-title"
                                value="{{ page.title }}">
                    </div>
                    <div class="pure-u-3-8">
                        <input type="text"
                                size="75"
                                name="{{ page.id }}-background_url"
                                value="{{ page.background_url }}">
                    </div>
                    <div class="pure-u-1-8">
                        <button type="submit"
                                name="delete"
                                value="{{ page.id }}"
                                class="pure-button red">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                </div>
            </li>
        {% endfor %}
        </ul>
        <div class="pure-g">
            <div class="pure-u-1-4" style="font-weight: bold;"> Nouvelle page </div>
            <div class="pure-u-1-4">
                <input type="text"
                        name="new-title"
                        placeholder="Titre de la page">
            </div>
            <div class="pure-u-3-8">
                <input type="text"
                        size="75"
                        name="new-background_url"
                        placeholder="URL de l'image de fond">
            </div>
            <div class="pure-u-1-8">
                <button type="submit"
                        name="form"
                        value="newPage"
                        class="pure-button green">
                    <i class="fa fa-circle-plus"></i>
                </button>
            </div>
        </div>
        <div class="is-right" style="margin-top: 15pt;">
            <button type="submit"
                    name="form"
                    value="pages"
                    class="pure-button green">
                <i class="fa-regular fa-floppy-disk"></i>
            </button>
        </div>
    </form>
</div>
<div id='soundTab' class="tabPage settings-menu is-center">
    <div class="pure-g">
        <div class="pure-u-1-3">Contexte</div>
        <div class="pure-u-1-3">URL du son</div>
        <div class="pure-u-1-3">Volume du son</div>
    </div>
    <form class="pure-form" 
            method="post">
        {% for sound in sounds %}
        <div class="pure-g">
            <div class="pure-u-1-3" style="font-weight:bold;">{{ sound.description }}</div>
            <div class="pure-u-1-3">
                <input type="text"
                        size="75"
                        name="{{ sound.context }}-url"
                        value="{{ sound.url }}">
            </div>
            <div class="pure-u-1-3">
                <input type="range"
                        name="{{ sound.context }}-volume"
                        min="0"
                        max="100"
                        step="1"
                        value="{{ sound.volume }}">
            </div>
        </div>
        {% endfor %}
        <div class="is-right"> 
            <button type="submit"
                    name="form"
                    value="sounds"
                    class="pure-button green">
                <i class="fa-regular fa-floppy-disk"></i>
            </button>
        </div>
    </form>
</div>
{%- endmacro -%}

{% block postscript %}
{% if message: %}
<div class="modal" id="message">
    <div class="modal-content">
        <div class="modal-menu is-center">
            <h1><i class="fa-solid fa-triangle-exclamation red is-center"></i> Erreur </h1>
        </div>
        <div class="modal-data">
            {{ message|safe }}
        </div>
        <div class="is-right">
            <div class="pure-button amber close">
                <i class="fa-solid fa-rotate-left"></i>
            </div>
        </div>
    </div>
</div>
<script>enableModal("message");</script>
{% endif %}
<script>
  new Sortable(
    document.getElementById('sortList'),
    { handle: '.handle',
     animation: 150
    });
  displayActiveTabContent();
  loadPagesCookies();
</script>
{% endblock postscript %}
