{% extends 'base.html.j2' %}


{% block head %}
<style>
body {
    background-image: linear-gradient(var(--edit-filter),var(--edit-filter)),url("{{ page.background_url }}");
}
.home-menu {
    border-style: ridge;
    border-color: var(--edit-color);
}
</style>
{%- endblock head -%}


{%- macro titleMenu() -%}
<span class="pure-menu-heading">{{ page.title }} [Edition]</span>
{%- endmacro -%}


{%- macro nav(classes='') -%}
<div class="pure-u-1-3 {{classes}} is-center">
    <a href="/{{previous}}/edit"
       class="pure-button"
       id="kbdPageDown">
        <i class="fa-solid fa-chevron-left"></i>
    </a>
</div>
<div class="pure-u-1-3 {{classes}} is-center">
    <a href="/settings"
       class="pure-button">
        <i class="fa-solid fa-wrench"></i>
    </a>
</div>
<div class="pure-u-1-3 {{classes}} is-center">
    <a href="/{{next}}/edit"
       class="pure-button"
       id="kbdPageUp">
        <i class="fa-solid fa-chevron-right"></i>
    </a>
</div>
{%- endmacro -%}


{%- macro buttonright() -%}
<div class="is-right">
    <button class="pure-button"
            id="toggleMuted"
            onclick="appMuted.switch()">
        <i class="fa-solid fa-volume-high"></i>
    </button>
    <button class="pure-button"
            id="editConfig"
            onclick="location.href='/{{ page.id }}';">
        <i class="fa-solid fa-window-restore"></i>
    </button>
</div>
{%- endmacro -%}


