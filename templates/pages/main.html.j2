{% extends 'base.html.j2' %}


{% block head %}
<script src="{{url_for('static', filename='js/keyboard.js')}}"></script>
<style>
body { 
    background-image: linear-gradient(var(--bg-filter),var(--bg-filter)),url("{{database.families[path].img}}");
}
</style>
{%- endblock head -%}


{%- block pageTitle -%}
<span class="pure-menu-heading" ondblclick="location.href='{{url_for('edit', path=path)}}'">{{database.families[path].title}}</span>
{%- endblock pageTitle -%}


{%- macro nav(classes='') -%}
<div class="pure-u-1-3 {{classes}} is-center"> <a href={{previous}} class="pure-button" id="kbdPageDown"> <i class="fa-solid fa-chevron-left"></i> </a> </div>
<div class="pure-u-1-3 {{classes}} is-center"> <a href={{database.config['mainPage']}} class="pure-button" id="kbdHome"> <i class="fa-solid fa-house"></i> </a> </div>
<div class="pure-u-1-3 {{classes}} is-center"> <a href={{next}} class="pure-button" id="kbdPageUp"> <i class="fa-solid fa-chevron-right"></i> </a> </div>
{%- endmacro -%}


{%- macro servers() -%}
<form class="" method="post" action="{{url_for('authenticated',path=path)}}">
{%- for id, server in database.servers.items() %}
    <li class="pure-menu-item recent-link">
        <button class="pure-button {{server.state}}" name="{{id}}" value="switch">
            <span class="tooltip"><div class="tooltiptext">{{server.name}}</div></span>
            <i class="{{ server.faIcon }}"></i>
        </button>
    </li>
{%- endfor %}
</form>
{%- endmacro -%}


{%- macro cards() -%}
{%- for id, card in database.families[path].dictOfCards.items() -%}
<div class="card-wrapper is-center">
    <div class="card">
        <div class="card-img" onclick="location.href='{{card.url}}';" id="kbd{{id}}">
            <img src="{{card.picture}}" onerror='src="{{url_for("static",filename="img/broken.png")}}"'> 
        </div>
        <div class="card-name is-center" onclick="enableModal('modal-{{id}}')">{{id}} <br><b>{{card.name}}</b></div>
    </div>
</div>
<div class="modal" id="modal-{{id}}">
    <div class="modal-content">
        <div class="modal-menu">
            <h1 >{{id}} - {{card.name}}</h1>
        </div>
        <div class="pure-g modal-data">
            <div class="pure-u-1 pure-u-md-1-3">
                <img src="{{card.picture}}" onerror='src="{{url_for("static",filename="img/broken.png")}}"'> 
            </div>
            <div class="pure-u-1 pure-u-md-2-3"><p>{{card.comments}}</p></div>
        </div>
        <div class="is-right">
            <div class="pure-button amber close is-right"><i class="fa-solid fa-rotate-left"></i></div>
        </div>
    </div>
</div>
{% endfor -%}

<script type="text/javascript">
    loadValues({{database.families[path].dictOfCards|length}},{{ratio}});
</script>
{%- endmacro -%}

{% block postscript %}
<div id="selectedChannel"></div>
{% endblock postscript %}
